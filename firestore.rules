// Copyright (c) 2026 NoHungryPets
// Firestore Security Rules for NoHungryPets Messaging System
// These rules should be deployed to Firebase Console

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Users can read their own stats but not modify others'
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Listings collection
    match /listings/{listingId} {
      allow read: if true; // Publicly readable

      // Only Listing owner can write/delete (except for claiming)
      allow create, delete: if request.auth != null
                            && request.auth.uid == resource.data.userId;

      // Allow updating listings: owner can modify any field,
      // any authenticated user can claim (update status to claimed)
      allow update: if request.auth != null
                    && (
                      // Owner can update any field
                      request.auth.uid == resource.data.userId
                      // OR any authenticated user can claim the listing
                      || (request.resource.data.keys().hasOnly(['status', 'claimedAt'])
                          && request.resource.data.status == 'claimed'
                          && request.resource.data.claimedAt != null)
                    );

      // For creating new listings, userId must match authenticated user
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // Conversations collection - core messaging functionality
    match /conversations/{conversationId} {
      // Allow participants to read conversations they're part of
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;

      // Allow creating conversations if user is one of the participants
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants
                    && size(request.resource.data.participants) == 2;

      // Allow updating conversation metadata (lastMessage, lastUpdated, etc.)
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants
                    // Only allow updating specific fields
                    && (request.resource.data.keys() - resource.data.keys())
                      .hasOnly(['lastMessage', 'lastUpdated', 'unreadCount',
                               'relatedListingId', 'relatedListingName'])

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.parent.parent.conversationId)).data.participants;

        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.senderId
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 1000 // Reasonable limit
                      && request.resource.data.timestamp != null;

        // Allow updating read status
        allow update: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.parent.parent.conversationId)).data.participants
                      && request.resource.data.keys().hasOnly(['read'])
                      && request.resource.data.read is bool;
      }
    }
  }
}